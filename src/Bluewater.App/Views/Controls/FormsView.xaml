<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Bluewater.App.ViewModels"
             xmlns:models="clr-namespace:Bluewater.App.Models"
             xmlns:helpers="clr-namespace:Bluewater.App.Helpers"
             x:Class="Bluewater.App.Views.Controls.FormsView"
             x:DataType="vm:FormsViewModel"
             Loaded="ContentView_Loaded"
             Unloaded="ContentView_Unloaded"
             Background="{StaticResource CollectionBackgroundBrush}">
    <Grid RowDefinitions="Auto,*,Auto"
          Padding="20"
          RowSpacing="12">
        <Grid Grid.Row="0"
              ColumnDefinitions="220,320,Auto,Auto,*"
              ColumnSpacing="10">
            <Picker Grid.Column="0"
                    Title="Select charging"
                    ItemsSource="{Binding Chargings}"
                    ItemDisplayBinding="{Binding Description}"
                    SelectedItem="{Binding SelectedCharging}" />
            <SearchBar Grid.Column="1"
                       Placeholder="Search employees"
                       VerticalOptions="End"
                       Text="{Binding SearchText}" />
            <Button Grid.Column="2"
                    Text="{x:Static helpers:Icon.RefreshCcw}"
                    FontFamily="Icons"
                    VerticalOptions="End"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding RefreshCommand}" />
            <Label Grid.Column="3"
                   VerticalTextAlignment="Center"
                   Text="{Binding Deductions.Count, StringFormat='{}{0} deductions'}" />
        </Grid>

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              RowSpacing="10">
            <Border StrokeShape="RoundRectangle 5 5 5 5"
                    Padding="12">
                <Grid ColumnDefinitions="1.2*,1.1*,Auto,Auto,Auto,Auto,Auto,Auto,1.2*,Auto"
                      ColumnSpacing="14"
                      RowSpacing="8">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 5 5 5 5"
                            Padding="10,8">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="0"
                              VerticalOptions="Center">
                            <Label Text="{Binding SelectedEmployee.FullName}" />
                            <Label Grid.Row="1"
                                   FontSize="12"
                                   Text="{Binding SelectedEmployee.PositionDisplay}" />
                        </Grid>
                    </Border>

                    <Picker Grid.Column="1"
                            Title="Deduction type"
                            ItemsSource="{Binding DeductionTypes}"
                            SelectedItem="{Binding SelectedDeductionType}">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Description" />
                        </Picker.ItemDisplayBinding>
                    </Picker>

                    <VerticalStackLayout Grid.Column="2" Spacing="6">
                        <Label Text="Total" />
                        <Entry Keyboard="Numeric"
                               WidthRequest="110"
                               TextChanged="TotalAmountEntry_TextChanged"
                               Text="{Binding EditableDeduction.TotalAmount}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="3" Spacing="6">
                        <Label Text="Monthly" />
                        <Entry Keyboard="Numeric"
                               WidthRequest="110"
                               IsEnabled="False"
                               Text="{Binding EditableDeduction.MonthlyAmortization}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="4" Spacing="6">
                        <Label Text="Balance" />
                        <Entry Keyboard="Numeric"
                               WidthRequest="110"
                               IsEnabled="False"
                               Text="{Binding EditableDeduction.RemainingBalance}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="5" Spacing="6">
                        <Label Text="Months" />
                        <Entry Keyboard="Numeric"
                               WidthRequest="80"
                               IsEnabled="False"
                               Text="{Binding EditableDeduction.NoOfMonths}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="6" Spacing="6">
                        <Label Text="Start date" />
                        <DatePicker Date="{Binding EditableDeduction.StartDate}"
                                    DateSelected="DatePicker_DateSelected" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="7" Spacing="6">
                        <Label Text="End date" />
                        <DatePicker Date="{Binding EditableDeduction.EndDate}"
                                    DateSelected="DatePicker_DateSelected" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="8" Spacing="6">
                        <Label Text="Remarks" />
                        <Entry Placeholder="Optional remarks"
                               Text="{Binding EditableDeduction.Remarks}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="9"
                            VerticalOptions="End"
                            Text="Save"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveDeductionCommand}" />
                </Grid>
            </Border>

            <CollectionView Grid.Row="1"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedDeduction}"
                            ItemsSource="{Binding Deductions}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="5" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DeductionSummary">
                        <Border StrokeShape="RoundRectangle 5 5 5 5">
                            <Grid Padding="10"
                                  ColumnDefinitions="*,Auto"
                                  VerticalOptions="Center"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" 
                                                     Spacing="4">
                                    <Label>
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Name}" />
                                                <Span Text=" • " />
                                                <Span Text="{Binding Type}" />
                                                <Span Text=" • ₱" />
                                                <Span Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Monthly: ₱" />
                                                <Span Text="{Binding MonthlyAmortization, StringFormat='{}{0:N2}'}" />
                                                <Span Text=" • Balance: ₱" />
                                                <Span Text="{Binding RemainingBalance, StringFormat='{}{0:N2}'}" />
                                                <Span Text=" • " />
                                                <Span Text="{Binding StartDate, StringFormat='{}{0:MMM dd, yyyy}'}" />
                                                <Span Text=" - " />
                                                <Span Text="{Binding EndDate, StringFormat='{}{0:MMM dd, yyyy}'}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label FontSize="12"
                                           Text="{Binding Remarks}" />
                                </VerticalStackLayout>
                                <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                    <Label HorizontalTextAlignment="End"
                                            Text="{Binding Status}" />
                                    <Button Text="Approve"
                                            Padding="12,6"
                                            IsEnabled="{Binding CanReview}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.ApproveDeductionCommand}"
                                            CommandParameter="{Binding .}" 
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Text="Reject"
                                            Padding="12,6"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            IsEnabled="{Binding CanReview}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.RejectDeductionCommand}"
                                            CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <ActivityIndicator Grid.RowSpan="4"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentView>
